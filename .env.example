#
# Configuration locale (développement)
#
# Laisse DATABASE_URL vide en local pour utiliser SQLite :
# data/internal_comms.db
DATABASE_URL=
SECRET_KEY=change-me-local-dev-secret
SESSION_HTTPS_ONLY=0
SESSION_MAX_AGE=604800
ALLOW_PUBLIC_REGISTRATION=1

#
# Sécurité / limites
#
RATE_LIMIT_LOGIN_MAX=30
RATE_LIMIT_LOGIN_WINDOW_SEC=300
RATE_LIMIT_REGISTER_MAX=8
RATE_LIMIT_REGISTER_WINDOW_SEC=3600
MESSAGE_EDIT_WINDOW_MINUTES=60
PRESENCE_ONLINE_SECONDS=180

#
# Production (Render) : exemple DATABASE_URL PostgreSQL
# Ne pas commiter de vraie URL ici.
#
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
